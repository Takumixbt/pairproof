# Shared CAP endpoint config (same for both agents unless CROO says otherwise)
CROO_API_URL=
CROO_WS_URL=
CROO_RPC_URL=

# Verifier agent identity (from the CROO dashboard, after registering the
# Verifier's service)
VERIFIER_SDK_KEY=
VERIFIER_SERVICE_ID=

# Builder agent identity
BUILDER_SDK_KEY=
BUILDER_SERVICE_ID=

# Verifier's public service_id, used by the Builder to hire it via CAP.
# Same value as VERIFIER_SERVICE_ID above -- kept separate because in
# production the Builder only needs to know this is a public listing, not a
# secret, whereas *_SDK_KEY values must never be committed.
CROO_VERIFIER_SERVICE_ID=

# Used by agent_builder/codegen.py (anthropic SDK reads this directly)
ANTHROPIC_API_KEY=
