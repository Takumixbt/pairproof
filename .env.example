# Shared CAP endpoint config -- confirmed defaults from docs.croo.network
# (developer-docs/quick-start). Override only if the dashboard shows
# something different for your account.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_RPC_URL=

# Verifier agent identity (from https://agent.croo.network -> My Agents ->
# Register Agent, then the service you add on its Configure page)
VERIFIER_SDK_KEY=
VERIFIER_SERVICE_ID=

# Builder agent identity
BUILDER_SDK_KEY=
BUILDER_SERVICE_ID=

# Verifier's public service_id, used by the Builder to hire it via CAP.
# Same value as VERIFIER_SERVICE_ID above -- kept separate because in
# production the Builder only needs to know this is a public listing, not a
# secret, whereas *_SDK_KEY values must never be committed.
CROO_VERIFIER_SERVICE_ID=

# Throwaway third agent used only to play the "human requester" role during
# testing -- CAP requires every negotiate_order() caller to be a registered
# agent, so testing the Builder's human-facing order needs its own identity.
TESTER_SDK_KEY=

# Codegen provider: "ollama" (default, free, local, no key needed -- requires
# `ollama serve` running with OLLAMA_MODEL pulled) or "anthropic" (paid API,
# needs ANTHROPIC_API_KEY below).
CODEGEN_PROVIDER=ollama
OLLAMA_MODEL=gemma4:e4b

# Only used when CODEGEN_PROVIDER=anthropic
ANTHROPIC_API_KEY=
